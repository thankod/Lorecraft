# Lorecraft Configuration
# Copy to: ~/.config/lorecraft/.env
#
#   mkdir -p ~/.config/lorecraft
#   cp .env.example ~/.config/lorecraft/.env
#
# Then fill in your API key below.

# --- Provider Selection ---
# auto (default) | gemini | anthropic
# LLM_PROVIDER=auto

# --- Google Gemini ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
