# Lorecraft Configuration
# Copy to: ~/.config/lorecraft/.env
#
#   mkdir -p ~/.config/lorecraft
#   cp .env.example ~/.config/lorecraft/.env
#
# Then fill in your API key below.

# --- Provider Selection ---
# auto (default) | gemini | anthropic | openai
# LLM_PROVIDER=auto

# --- Google Gemini ---
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# --- OpenAI / OpenAI-Compatible APIs ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  (optional, for compatible APIs like Ollama, vLLM, etc.)
