{
  "name": "lorecraft",
  "version": "0.1.0",
  "description": "AI-driven dialogue CRPG engine framework",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "start": "node --import tsx/esm src/main.ts",
    "dev": "node --import tsx/esm --watch src/main.ts",
    "web:dev": "cd web && pnpm dev",
    "web:build": "cd web && pnpm build",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "crpg",
    "ai",
    "game-engine",
    "narrative"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/sql.js": "^1.4.10",
    "@types/ws": "^8.18.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.83",
    "@ai-sdk/anthropic": "^3.0.64",
    "@ai-sdk/azure": "^3.0.49",
    "@ai-sdk/cohere": "^3.0.27",
    "@ai-sdk/deepseek": "^2.0.26",
    "@ai-sdk/google": "^3.0.53",
    "@ai-sdk/groq": "^3.0.31",
    "@ai-sdk/mistral": "^3.0.27",
    "@ai-sdk/openai": "^3.0.48",
    "@ai-sdk/perplexity": "^3.0.26",
    "@ai-sdk/togetherai": "^2.0.41",
    "@ai-sdk/xai": "^3.0.74",
    "ai": "^6.0.138",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^17.3.1",
    "undici": "^7.24.5",
    "ws": "^8.20.0",
    "zod": "^4.3.6"
  }
}